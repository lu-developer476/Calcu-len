{
  "version": 2,
  "name": "calcu-len",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.py"
    },
    {
      "src": "^/(.*)$",
      "dest": "/public/$1"
    }
  ]
}
