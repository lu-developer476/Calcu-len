{
  "version": 2,
  "name": "calcu-len",
  "builds": [
    {
      "src": "api/vercel_app.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "^/api/index[.]py/(.*)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/api/vercel_app[.]py/(.*)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/vercel_app.py/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/public/$1"
    }
  ]
}
